# Demo auth is intentionally development-only and fails closed in production.
ENABLE_DEMO_AUTH=true
DEMO_ADMIN_ID=local-demo-admin
DEMO_ADMIN_EMAIL=admin@example.test
DEMO_ADMIN_PASSWORD=replace-with-a-local-only-password
DEMO_ADMIN_ROLE=SUPER_ADMIN

# Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-bytes

# Prefer same-origin API calls through /api.
NEXT_PUBLIC_API_URL=/api
